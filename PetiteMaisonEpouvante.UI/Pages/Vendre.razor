@page "/vendre"
@page "/vendre/produits"
@using PetiteMaisonEpouvante.Core
@using PetiteMaisonEpouvante.UI.Services
@using System.Net.Http.Headers 
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IAuthenticationService AuthService
@implements IAsyncDisposable

<PageTitle>Vendre vos produits - Petite Maison de l'Épouvante</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Proposer vos produits à la vente</h1>
            <p class="lead">Vendez vos propriétés figurines, goodies, CD/DVD Blu-ray, jeux de plateau ...</p>
        </div>
        <div class="text-end">
            @if (isAuthenticated)
            {
                <div class="alert alert-success mb-2" role="alert">
                    ✅ Connecté as: <strong>@currentUserName</strong>
                </div>
                <button class="btn btn-warning btn-sm" @onclick="HandleLogout">
                    Déconnexion
                </button>
            }
            else
            {
                <button class="btn btn-primary btn-sm" @onclick="HandleSimulateLogin">
                    🔐 Simuler une connexion
                </button>
            }
        </div>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <h3>Ajouter un nouveau produit</h3>
            @if (!isAuthenticated)
            {
                <div class="alert alert-warning" role="alert">
                    <strong>⚠️ Connexion requise</strong><br>
                    Veuillez cliquer sur le bouton "Simuler une connexion" en haut à droite pour commencer.
                </div>
            }
            else
            {
                <EditForm Model="@newProduct" OnValidSubmit="@HandleValidSubmit">
                    <DataAnnotationsValidator />
                
                    <div class="mb-3">
                        <label>Nom du produit :</label>
                        <InputText @bind-Value="newProduct.Name" class="form-control" />
                        <ValidationMessage For="@(() => newProduct.Name)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label>Description :</label>
                        <InputTextArea @bind-Value="newProduct.Description" class="form-control" rows="4" />
                        <ValidationMessage For="@(() => newProduct.Description)" class="text-danger" />
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Prix (€) :</label>
                            <InputNumber @bind-Value="newProduct.Price" class="form-control" />
                            <ValidationMessage For="@(() => newProduct.Price)" class="text-danger" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Frais de port (€) :</label>
                            <InputNumber @bind-Value="newProduct.ShippingCost" class="form-control" />
                            <ValidationMessage For="@(() => newProduct.ShippingCost)" class="text-danger" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Stock :</label>
                            <InputNumber @bind-Value="newProduct.Stock" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Catégorie :</label>
                            <InputSelect @bind-Value="newProduct.CategoryId" class="form-control">
                                <option value="">-- Sélectionner une catégorie --</option>
                                @if (categories != null)
                                {
                                    @foreach (var category in categories)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => newProduct.CategoryId)" class="text-danger" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label>Photo (URL) :</label>
                            <InputText @bind-Value="newProduct.PhotoUrl" class="form-control" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting) { <span>⏳ Ajout en cours...</span> } 
                        else { <span>✅ Ajouter le produit</span> }
                    </button>
                </EditForm>
            }
        </div>

        <div class="col-md-6">
            <h3>Vos produits</h3>
            @if (userProducts == null)
            {
                <p><em>Chargement de vos produits...</em></p>
            }
            else if (!userProducts.Any())
            {
                <div class="alert alert-info">
                    Vous n'avez pas encore ajouté de produits.
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var product in userProducts)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-0">@product.Name</h6>
                                    <small class="text-muted">@product.Price.ToString("C") | Stock: @product.Stock</small>
                                </div>
                                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteProduct(product.Id))">
                                    Supprimer
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private Product newProduct = new Product { Stock = 1, ShippingCost = 5 };
    private List<Product> userProducts = new List<Product>();
    private List<Category> categories = new List<Category>();
    private string? errorMessage;
    private string? successMessage;
    private bool isSubmitting = false;
    private bool isAuthenticated = false;
    private string? currentUserId;
    private string? currentUserName;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to authentication changes
        AuthService.OnAuthenticationChanged += OnAuthenticationChanged;
        
        // Check current authentication status
        await CheckAuthenticationStatus();
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            // Try to get categories from the dedicated endpoint
            categories = await Http.GetFromJsonAsync<List<Category>>("api/products/categories") ?? new List<Category>();
            
            // Set default category if available
            if (categories.Any() && newProduct.CategoryId == null)
            {
                newProduct.CategoryId = categories.First().Id;
            }
        }
        catch
        {
            // Categories endpoint may not exist yet, continue without categories
        }
    }

    private async void OnAuthenticationChanged()
    {
        await CheckAuthenticationStatus();
        StateHasChanged();
    }

    private async Task CheckAuthenticationStatus()
    {
        isAuthenticated = await AuthService.IsAuthenticated();
        var user = await AuthService.GetCurrentUser();
        
        if (user.HasValue)
        {
            currentUserId = user.Value.UserId;
            currentUserName = user.Value.UserName;
            await LoadUserProducts();
        }
        else
        {
            currentUserId = null;
            currentUserName = null;
            userProducts = new List<Product>();
        }
    }

    private async Task HandleSimulateLogin()
    {
        // Create a demo user
        string userId = "seller-" + Guid.NewGuid().ToString().Substring(0, 8);
        string userName = "Vendeur Test";
        
        await AuthService.SimulateLogin(userId, userName);
        await CheckAuthenticationStatus();
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        await CheckAuthenticationStatus();
    }

    private async Task LoadUserProducts()
    {
        try
        {
            if (string.IsNullOrEmpty(currentUserId))
                return;

            var allProducts = await Http.GetFromJsonAsync<List<Product>>("api/products");
            userProducts = allProducts?.Where(p => p.SellerId == currentUserId).ToList() ?? new List<Product>();
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors du chargement des produits : " + ex.Message;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "Vous devez d'abord simuler une connexion.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            newProduct.SellerId = currentUserId;
            newProduct.CreatedAt = DateTime.UtcNow;
            
            // If no category selected, use the first one
            if (newProduct.CategoryId == null && categories.Any())
            {
                newProduct.CategoryId = categories.First().Id;
            }

            var response = await Http.PostAsJsonAsync("api/products", newProduct);
            
            if (response.IsSuccessStatusCode)
            {
                successMessage = "✅ Produit ajouté avec succès !";
                newProduct = new Product { Stock = 1, ShippingCost = 5 };
                if (categories.Any())
                {
                    newProduct.CategoryId = categories.First().Id;
                }
                await LoadUserProducts();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Erreur lors de l'ajout : {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur réseau : " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteProduct(Guid productId)
    {
        if (!await ConfirmDelete("Êtes-vous sûr de vouloir supprimer ce produit ?"))
            return;

        try
        {
            var response = await Http.DeleteAsync($"api/products/{productId}");
            if (response.IsSuccessStatusCode)
            {
                successMessage = "✅ Produit supprimé";
                await LoadUserProducts();
            }
            else
            {
                errorMessage = "Erreur lors de la suppression";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur : " + ex.Message;
        }
    }

    private async Task<bool> ConfirmDelete(string message)
    {
        // En Blazor, utiliser JavaScript pour les confirmations
        return await Task.FromResult(true);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        AuthService.OnAuthenticationChanged -= OnAuthenticationChanged;
    }
}